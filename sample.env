# Azure RAG Indexing Lab - Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# Azure Resource Group
# ============================================
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=your-resource-group-name
AZURE_LOCATION=swedencentral

# ============================================
# Azure Storage Account (Blob)
# ============================================
AZURE_STORAGE_ACCOUNT_NAME=stragindexinglab
# MI 기반 인증 사용, connection string 불필요
# AZURE_STORAGE_CONNECTION_STRING=your-connection-string
AZURE_STORAGE_CONTAINER_NAME=raw-documents
AZURE_STORAGE_RESOURCE_ID=/subscriptions/<sub-id>/resourceGroups/<rg-name>/providers/Microsoft.Storage/storageAccounts/<storage-account-name>
BLOB_CONTAINER_NAME=raw-documents

# ============================================
# Azure OpenAI
# ============================================
AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com
AZURE_OPENAI_API_KEY=your-openai-key
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-large
AZURE_OPENAI_GPT54_DEPLOYMENT=gpt-5.4
AZURE_OPENAI_GPT54_MODEL=gpt-5.4

# ============================================
# Azure AI Search
# ============================================
AZURE_SEARCH_SERVICE_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_ADMIN_KEY=your-search-admin-key
AZURE_SEARCH_INDEX_NAME=law-documents-index

# ============================================
# Azure Document Intelligence
# ============================================
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-doc-intel.cognitiveservices.azure.com
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-doc-intel-key

# ============================================
# Azure Logic Apps
# ============================================
AZURE_LOGIC_APP_NAME=logic-rag-indexing-lab
AZURE_LOGIC_APP_RESOURCE_GROUP=rg-rag-indexing-lab

# ============================================
# Custom Skills Function App (더 이상 사용하지 않음)
# B-1~B-4 파이프라인이 Built-in Skill만 사용하도록 변경됨
# ============================================
# SKILLS_FUNCTION_URL=https://func-skills-ragi-XXXXXXXX.azurewebsites.net
# SKILLS_FUNCTION_KEY=your-function-key

# ============================================
# Data Crawling
# ============================================
LAW_CRAWL_BASE_URL=https://www.law.go.kr
LAW_CRAWL_LIMIT=10

# ============================================
# Azure AI Foundry
# ============================================
FOUNDRY_PROJECT_ENDPOINT=https://ais-ragi-<suffix>.services.ai.azure.com/api/projects/proj-ragi-default
